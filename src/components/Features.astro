---
import { Card, CardTitle, CardDescription, CardContent } from './ui/Card';
import { Badge } from './ui/Badge';
import { Button } from './ui/Button';
---

<section id="features" class="py-24 bg-surface-primary relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 max-w-3xl mx-auto">
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-6">
        Características que <span class="text-accent-blue">transformarán</span> tu vida financiera
      </h2>
      <p class="text-xl text-text-secondary leading-relaxed">
        Herramientas avanzadas diseñadas para simplificar la gestión de tus finanzas personales con la elegancia que mereces.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      <!-- Feature 1 -->
      <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col gap-4 border-white/5 bg-surface-secondary/20">
        <div class="w-12 h-12 rounded-xl bg-accent-blue/10 flex items-center justify-center text-accent-blue mb-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <CardTitle>Gestión de Presupuestos</CardTitle>
        <CardDescription className="text-base leading-relaxed">
          Crea presupuestos inteligentes por categorías con límites personalizables y alertas automáticas de sobre-gasto.
        </CardDescription>
        <CardContent className="mt-auto pt-4 flex items-center gap-2">
          <Badge client:load variant="primary" size="sm" className="st-status-active-primary">Premium</Badge>
          <span class="text-xs text-text-tertiary">Presupuestos ilimitados</span>
        </CardContent>
      </Card>

      <!-- Feature 2 -->
      <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col gap-4 border-white/5 bg-surface-secondary/20">
        <div class="w-12 h-12 rounded-xl bg-status-info/10 flex items-center justify-center text-status-info mb-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 3V21H21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9 9L12 6L16 10L21 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <CardTitle>Analíticas en Tiempo Real</CardTitle>
        <CardDescription className="text-base leading-relaxed">
          Dashboard interactivo con gráficos en tiempo real, reportes mensuales y proyecciones de gastos con IA.
        </CardDescription>
        <CardContent className="mt-auto pt-4 flex items-center gap-2">
          <Badge client:load variant="info" size="sm" dot className="st-status-active-tertiary text-black">IA</Badge>
          <span class="text-xs text-text-tertiary">Predicciones inteligentes</span>
        </CardContent>
      </Card>


      <!-- Feature 4 -->
      <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col gap-4 border-white/5 bg-surface-secondary/20">
        <div class="w-12 h-12 rounded-xl bg-status-success/10 flex items-center justify-center text-status-success mb-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 12L11 14L15 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <CardTitle>Objetivos Financieros</CardTitle>
        <CardDescription className="text-base leading-relaxed">
          Define metas de ahorro con tracking automático y recibe sugerencias personalizadas para alcanzarlas.
        </CardDescription>
        <CardContent className="mt-auto pt-4 flex items-center gap-2">
          <Badge client:load variant="success" size="sm" className="st-status-complete-primary">Motivador</Badge>
          <span class="text-xs text-text-tertiary">Gamificación incluida</span>
        </CardContent>
      </Card>

      <!-- Feature 5 -->
      <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col gap-4 border-white/5 bg-surface-secondary/20">
        <div class="w-12 h-12 rounded-xl bg-accent-blue/10 flex items-center justify-center text-accent-blue mb-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
            <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <CardTitle>Transacciones Recurrentes</CardTitle>
        <CardDescription className="text-base leading-relaxed">
          Automatiza suscripciones, salarios y gastos fijos. La app los registra automáticamente cada mes.
        </CardDescription>
        <CardContent className="mt-auto pt-4 flex items-center gap-2">
          <Badge client:load variant="primary" size="sm" className="st-status-active-primary">Auto</Badge>
          <span class="text-xs text-text-tertiary">Configura una vez</span>
        </CardContent>
      </Card>

      <!-- Feature 6 -->
      <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col gap-4 border-white/5 bg-surface-secondary/20">
        <div class="w-12 h-12 rounded-xl bg-status-error/10 flex items-center justify-center text-status-error mb-2">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <CardTitle>Seguridad Avanzada</CardTitle>
        <CardDescription className="text-base leading-relaxed">
          Autenticación biométrica, cifrado de extremo a extremo y PIN de acceso rápido para máxima seguridad.
        </CardDescription>
        <CardContent className="mt-auto pt-4 flex items-center gap-2">
          <Badge client:load variant="error" size="sm" className="st-status-rejected-primary">AES-256</Badge>
          <span class="text-xs text-text-tertiary">Cifrado militar</span>
        </CardContent>
      </Card>
    </div>

    <!-- CTA Section within Features -->
    <Card client:load variant="flat" className="bg-surface-secondary/50 border border-border-secondary/50 overflow-hidden relative">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_100%_100%,rgba(0,102,204,0.03),transparent_40%)]"></div>
      <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8 p-10">
        <div class="text-center md:text-left">
          <h3 class="text-2xl font-bold text-text-primary mb-2">¿Listo para transformar tus finanzas?</h3>
          <p class="text-text-secondary">Únete a más de 50,000 usuarios que ya tomaron el control.</p>
        </div>
        <a href="#pricing">
          <Button client:load variant="primary" size="lg" className="whitespace-nowrap shadow-apple-md">
            Ver planes disponibles
          </Button>
        </a>
      </div>
    </Card>
  </div>
</section>