---
import { Card, CardTitle, CardDescription, CardContent } from './ui/Card';
import { Badge } from './ui/Badge';

const testimonials = [
  {
    name: "María González",
    role: "Diseñadora UX",
    image: "https://images.pexels.com/photos/774909/pexels-photo-774909.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&dpr=2",
    quote: "Gracias a Capitalia logré ahorrar $5,000 en solo 6 meses. Las Recomendaciones con IA me ayudaron a identificar gastos innecesarios que ni sabía que tenía.",
    stats: { label1: "$5,000", value1: "Ahorrados", label2: "6 meses", value2: "Uso" }
  },
  {
    name: "Carlos Ruiz",
    role: "Desarrollador",
    image: "https://images.pexels.com/photos/1040880/pexels-photo-1040880.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&dpr=2",
    quote: "La funcionalidad offline es increíble. Viajo mucho por trabajo y siempre puedo registrar mis gastos, sin importar si tengo internet o no.",
    stats: { label1: "100%", value1: "Confiable", label2: "1 año", value2: "Premium" }
  },
  {
    name: "Ana Martínez",
    role: "Emprendedora",
    image: "https://images.pexels.com/photos/415829/pexels-photo-415829.jpeg?auto=compress&cs=tinysrgb&w=100&h=100&dpr=2",
    quote: "El sistema de presupuestos me cambió la vida. Por primera vez en años, sé exactamente en qué gasto mi dinero y tengo control total.",
    stats: { label1: "35%", value1: "Ahorro", label2: "8 meses", value2: "Uso" }
  }
];
---

<section id="testimonials" class="py-24 bg-surface-secondary/10 relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-20 max-w-3xl mx-auto">
      <Badge client:load variant="info" size="md" className="mb-4 font-bold">TESTIMONIOS</Badge>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-6">
        Lo que dicen nuestros <span class="text-accent-blue font-black underline decoration-accent-blue/10 underline-offset-8">usuarios</span>
      </h2>
      <p class="text-xl text-text-secondary leading-relaxed">
        Miles de personas han transformado su relación con el dinero usando Capitalia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      {testimonials.map((t) => (
        <Card client:load variant="glass" hoverable padding="lg" className="flex flex-col border-border-secondary/40">
          <div class="flex items-center gap-4 mb-6">
            <img src={t.image} alt={t.name} class="w-12 h-12 rounded-full border-2 border-accent-blue/20 p-0.5 object-cover" />
            <div>
              <h4 class="font-bold text-text-primary leading-tight">{t.name}</h4>
              <p class="text-xs text-text-tertiary uppercase tracking-wider font-bold">{t.role}</p>
            </div>
            <div class="ml-auto flex text-status-warning text-xs">⭐⭐⭐⭐⭐</div>
          </div>
          
          <blockquote class="text-base text-text-secondary italic leading-relaxed mb-8 flex-1">
            "{t.quote}"
          </blockquote>

          <div class="grid grid-cols-2 gap-4 pt-6 border-t border-border-secondary/30">
            <div>
              <p class="text-lg font-black text-accent-blue tracking-tight">{t.stats.label1}</p>
              <p class="text-[10px] text-text-tertiary uppercase font-bold tracking-widest">{t.stats.value1}</p>
            </div>
            <div>
              <p class="text-lg font-black text-text-primary tracking-tight">{t.stats.label2}</p>
              <p class="text-[10px] text-text-tertiary uppercase font-bold tracking-widest">{t.stats.value2}</p>
            </div>
          </div>
        </Card>
      ))}
    </div>

    {/* Social Proof Bar */}
    <Card client:load variant="elevated" className="bg-accent-blue text-white overflow-hidden relative border-none shadow-apple-lg">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_100%_0%,rgba(255,255,255,0.15),transparent_40%)]"></div>
      <div class="relative z-10 grid grid-cols-2 md:grid-cols-4 gap-8 p-10 text-center">
        <div>
          <p class="text-3xl font-black tracking-tight mb-1 font-sans">50,000+</p>
          <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80">Usuarios</p>
        </div>
        <div>
          <p class="text-3xl font-black tracking-tight mb-1 font-sans">$2M+</p>
          <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80">Ahorrado</p>
        </div>
        <div>
          <p class="text-3xl font-black tracking-tight mb-1 font-sans">4.9/5</p>
          <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80">Rating</p>
        </div>
        <div>
          <p class="text-3xl font-black tracking-tight mb-1 font-sans">99.9%</p>
          <p class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80">Uptime</p>
        </div>
      </div>
    </Card>
  </div>
</section>