---
import { Card, CardTitle, CardDescription, CardContent, CardHeader } from './ui/Card';
import { Badge } from './ui/Badge';
import { Button } from './ui/Button';
import { StatisticDisplay } from './ui/StatisticDisplay';
import { motion } from 'framer-motion';

const demoMetrics = [
  {
    label: "Balance Total",
    value: "$12,847.50",
    change: "+10.6%",
    trend: "up" as const,
    subtle: false,
    sparklineAccent: "blue" as const,
    sparkline: [40, 45, 42, 48, 52, 50, 55],
  },
  {
    label: "Ingresos",
    value: "$8,500.00",
    change: "+6.2%",
    trend: "up" as const,
    subtle: true,
    sparklineAccent: "green" as const,
    sparkline: [30, 32, 35, 33, 38, 40, 42],
  },
  {
    label: "Gastos",
    value: "$6,266.00",
    change: "-3.6%",
    trend: "down" as const,
    subtle: true,
    sparklineAccent: "orange" as const,
    sparkline: [25, 28, 22, 24, 26, 23, 21],
  }
];
---

<section id="demo" class="py-24 bg-surface-secondary/20 relative overflow-hidden">
  <!-- Decorative background element -->
  <div class="absolute top-0 right-0 -z-10 w-[500px] h-[500px] bg-accent-blue/5 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
  
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left side: Information -->
      <div class="flex flex-col items-start gap-8">
        <Badge client:load variant="primary" size="md" dot className="font-bold">
          🎯 Dashboard en vivo
        </Badge>
        
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary leading-[1.2]">
          Visualiza tus finanzas con <br class="hidden md:block" />
          <span class="text-accent-blue font-black underline decoration-accent-blue/20 underline-offset-8">analíticas avanzadas</span>
        </h2>
        
        <p class="text-xl text-text-secondary leading-relaxed max-w-lg">
          Nuestro dashboard inteligente te muestra exactamente dónde va tu dinero, con gráficos interactivos y predicciones automáticas basadas en tus hábitos.
        </p>

        <div class="space-y-6 w-full max-w-md">
          <div class="flex items-center gap-4 group cursor-default">
            <div class="w-12 h-12 rounded-2xl bg-surface-secondary border border-border-secondary shadow-apple-sm flex items-center justify-center text-xl group-hover:scale-110 transition-apple">✨</div>
            <div>
              <p class="font-bold text-text-primary">Predicciones IA</p>
              <p class="text-sm text-text-tertiary">Proyecciones de gastos futuras personalizadas.</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 group cursor-default">
            <div class="w-12 h-12 rounded-2xl bg-surface-secondary border border-border-secondary shadow-apple-sm flex items-center justify-center text-xl group-hover:scale-110 transition-apple">📊</div>
            <div>
              <p class="font-bold text-text-primary">Gráficos interactivos</p>
              <p class="text-sm text-text-tertiary">Visualización táctil de cada categoría de gasto.</p>
            </div>
          </div>

          <div class="flex items-center gap-4 group cursor-default">
            <div class="w-12 h-12 rounded-2xl bg-surface-secondary border border-border-secondary shadow-apple-sm flex items-center justify-center text-xl group-hover:scale-110 transition-apple">🔍</div>
            <div>
              <p class="font-bold text-text-primary">Análisis detallado</p>
              <p class="text-sm text-text-tertiary">Insights profundos para optimizar tu ahorro.</p>
            </div>
          </div>
        </div>

        <Button client:load variant="primary" size="lg" className="mt-4 shadow-apple-md">
          Probar dashboard interactivo
        </Button>
      </div>

      <!-- Right side: Mockup -->
      <div class="relative group">
        <!-- Mockup Container -->
        <Card client:load variant="glass" padding="none" className="overflow-hidden border-border-secondary/60 shadow-apple-xl ring-1 ring-white/10 translate-y-4 group-hover:translate-y-0 transition-apple-slow bg-surface-primary/40">
          <!-- Toolbar 스타일 헤더 -->
          <div class="bg-surface-secondary border-b border-border-secondary p-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="flex gap-1.5 mr-4">
                <div class="w-3 h-3 rounded-full bg-status-error/40"></div>
                <div class="w-3 h-3 rounded-full bg-status-warning/40"></div>
                <div class="w-3 h-3 rounded-full bg-status-success/40"></div>
              </div>
              <div>
                <CardTitle className="text-sm mb-0! font-bold">Capitalia Dashboard</CardTitle>
                <CardDescription className="text-[10px] uppercase tracking-widest font-bold opacity-60">Marzo 2024</CardDescription>
              </div>
            </div>
            <div class="w-8 h-8 rounded-full bg-accent-blue/10 flex items-center justify-center text-accent-blue text-xs font-bold">3</div>
          </div>

          <div class="p-6 space-y-8">
            <!-- Stats Grid -->
            <StatisticDisplay client:load metrics={demoMetrics} columns={1} size="sm" variant="soft" gap="sm" className="lg:grid-cols-3" />

            <!-- Category Chart Mockup -->
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                 <h4 class="text-sm font-bold text-text-primary uppercase tracking-wider">Gastos por Categoría</h4>
                 <Badge client:load size="sm" variant="default" className="text-[10px] font-bold">ESTE MES</Badge>
              </div>
              
              <div class="space-y-3">
                {[
                  { label: "Comida", val: "$2,193", perc: 35, color: "bg-status-warning" },
                  { label: "Transporte", val: "$1,567", perc: 25, color: "bg-accent-blue" },
                  { label: "Ocio", val: "$1,253", perc: 20, color: "bg-accent-purple" },
                  { label: "Compras", val: "$940", perc: 15, color: "bg-status-error" }
                ].map(item => (
                  <div class="group/bar">
                    <div class="flex justify-between text-xs font-medium mb-1.5">
                      <span class="text-text-secondary">{item.label}</span>
                      <span class="text-text-primary font-bold">{item.val}</span>
                    </div>
                    <div class="h-2 w-full bg-surface-secondary rounded-full overflow-hidden">
                      <div class={`h-full rounded-full ${item.color} group-hover/bar:brightness-110 transition-all duration-700`} style={{ width: `${item.perc}%` }}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Insights Section -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
               <Card client:load variant="flat" padding="sm" className="bg-accent-purple/5 border-accent-purple/10">
                  <div class="flex items-center gap-3">
                    <div class="text-xl">🤖</div>
                    <div class="flex-1">
                      <p class="text-[10px] font-bold text-accent-purple uppercase tracking-tight">IA Insight</p>
                      <p class="text-xs text-text-primary font-medium leading-tight">Ahorra $150 optimizando gastos en comida.</p>
                    </div>
                  </div>
               </Card>

               <Card client:load variant="flat" padding="sm" className="bg-status-success/5 border-status-success/10">
                  <div class="flex items-start gap-3">
                    <div class="text-xl">🎯</div>
                    <div class="flex-1">
                      <p class="text-[10px] font-bold text-status-success uppercase tracking-tight">Meta de Ahorro</p>
                      <div class="flex items-center justify-between mb-1">
                         <span class="text-[10px] font-bold text-text-primary">75%</span>
                         <span class="text-[10px] text-text-tertiary">$5,000</span>
                      </div>
                      <div class="h-1 w-full bg-surface-secondary rounded-full overflow-hidden">
                        <div class="h-full bg-status-success rounded-full" style="width: 75%"></div>
                      </div>
                    </div>
                  </div>
               </Card>
            </div>
          </div>
        </Card>

        <!-- Shadow Glow behind mockup -->
        <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-[90%] h-20 bg-accent-blue/10 blur-[80px] -z-10 rounded-full"></div>
      </div>
    </div>
  </div>
</section>