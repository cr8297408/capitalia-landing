---
import { 
  Footer as FooterRoot, 
  FooterTop, 
  FooterContent, 
  FooterColumn, 
  FooterLink, 
  FooterBottom 
} from './ui/Footer';
import { Badge } from './ui/Badge';
---

<FooterRoot client:load className="bg-surface-primary border-t border-border-secondary/50">
  <div class="max-w-7xl mx-auto px-6">
    {/* Footer Top: Brand & Identity */}
    <div class="flex flex-col md:flex-row justify-between items-start gap-12 mb-16">
      <div class="max-w-sm">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">💰</span>
          <span class="text-xl font-black tracking-tight text-text-primary">Capitalia</span>
        </div>
        <p class="text-text-secondary text-sm leading-relaxed mb-6">
          La plataforma definitiva para la libertad financiera. Gestiona, ahorra y crece con tecnología diseñada para personas reales.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-8 h-8 rounded-full bg-surface-secondary flex items-center justify-center text-text-tertiary hover:text-accent-blue transition-apple">𝕏</a>
          <a href="#" class="w-8 h-8 rounded-full bg-surface-secondary flex items-center justify-center text-text-tertiary hover:text-accent-blue transition-apple">In</a>
          <a href="#" class="w-8 h-8 rounded-full bg-surface-secondary flex items-center justify-center text-text-tertiary hover:text-accent-blue transition-apple">Gh</a>
        </div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-12 md:gap-24">
        <div>
          <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-text-tertiary mb-6">Producto</h4>
          <ul class="space-y-4">
            <li><FooterLink href="#features">Características</FooterLink></li>
            <li><FooterLink href="#demo">Demo en vivo</FooterLink></li>
            <li><FooterLink href="#pricing">Precios</FooterLink></li>
            <li><FooterLink href="/comprar">Comprar Proyecto <Badge client:load size="sm" variant="info" className="ml-1 scale-75 origin-left">PRO</Badge></FooterLink></li>
            <li><FooterLink href="/updates">Novedades <Badge client:load size="sm" variant="success" className="ml-1 scale-75 origin-left">NEW</Badge></FooterLink></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-text-tertiary mb-6">Compañía</h4>
          <ul class="space-y-4">
            <li><FooterLink href="/about">Nosotros</FooterLink></li>
            <li><FooterLink href="/careers">Carreras</FooterLink></li>
            <li><FooterLink href="/blog">Blog</FooterLink></li>
            <li><FooterLink href="mailto:coder4021@gmail.com">Contacto</FooterLink></li>
          </ul>
        </div>
        <div>
          <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-text-tertiary mb-6">Legal</h4>
          <ul class="space-y-4">
            <li><FooterLink href="/privacy">Privacidad</FooterLink></li>
            <li><FooterLink href="/terms">Términos</FooterLink></li>
            <li><FooterLink href="/cookies">Cookies</FooterLink></li>
          </ul>
        </div>
      </div>
    </div>

    {/* Footer Bottom */}
    <div class="pt-8 border-t border-border-secondary/30 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-[11px] font-bold text-text-tertiary uppercase tracking-widest">
        © 2024 Capitalia Finance — Diseñado en California.
      </p>
      
      <div class="flex items-center gap-6">
        <span class="text-[10px] font-bold text-status-success flex items-center gap-1.5 uppercase tracking-widest">
          <span class="w-1.5 h-1.5 rounded-full bg-status-success animate-pulse"></span>
          Todos los sistemas operativos
        </span>
        <div class="h-4 w-px bg-border-secondary/50"></div>
        <select class="bg-transparent text-[10px] font-bold text-text-tertiary uppercase tracking-widest outline-none border-none cursor-pointer hover:text-text-primary transition-apple">
          <option>Español (ES)</option>
          <option>English (US)</option>
        </select>
      </div>
    </div>
  </div>
</FooterRoot>