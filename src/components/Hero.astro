---
import { NavBar, NavBarBrand, NavBarContent, NavBarItem } from './ui/NavBar';
import { Button } from './ui/Button';
import { Badge } from './ui/Badge';
import { motion } from 'framer-motion';
---

<section class="relative min-h-screen pt-20 overflow-hidden bg-surface-primary">
  <!-- Mesh Gradient Background -->
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_0%,rgba(0,102,204,0.08),transparent_50%),radial-gradient(circle_at_100%_100%,rgba(0,102,204,0.05),transparent_50%)]"></div>

  <!-- NavBar -->
  <NavBar client:load>
    <NavBarBrand href="/" className="flex items-center gap-2">
      <span class="text-2xl">💰</span>
      <span class="font-bold tracking-tight text-text-primary">Capitalia</span>
    </NavBarBrand>
    
    <NavBarContent align="center" className="hidden md:flex">
      <NavBarItem active href="#features">Características</NavBarItem>
      <NavBarItem href="#pricing">Precios</NavBarItem>
      <NavBarItem href="#contact">Contacto</NavBarItem>
    </NavBarContent>
    
    <NavBarContent align="right">
      <Button client:load variant="primary" size="sm" className="hidden sm:flex">
        Descargar App
      </Button>
    </NavBarContent>
  </NavBar>

  <div class="max-w-7xl mx-auto px-6 pt-20 pb-32">
    <div class="grid lg:grid-template-columns-2 lg:grid-cols-2 gap-16 items-center">
      <!-- Left Column: Text Content -->
      <div class="flex flex-col items-start gap-8">
        <Badge client:load variant="info" size="md" className="font-semibold px-4 py-1">
          ✨ Nuevo: Recomendaciones con IA
        </Badge>
        
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-text-primary leading-[1.1]">
          Gestiona tus finanzas <br class="hidden md:block" />
          <span class="text-accent-blue">como un profesional</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-text-secondary leading-relaxed max-w-xl">
          La plataforma más completa para gestionar tus presupuestos, rastrear gastos y alcanzar tus metas financieras con analíticas en tiempo real.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <Button client:load variant="primary" size="lg" className="px-8 shadow-apple-md">
            Comenzar gratis
            <svg class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </Button>
          
          <Button client:load variant="secondary" size="lg" className="px-8 border-border-primary/50">
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polygon points="5,3 19,12 5,21" fill="currentColor"/>
            </svg>
            Ver demo
          </Button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-8 pt-8 w-full border-t border-border-secondary/50">
          <div>
            <div class="text-2xl font-bold text-text-primary">50K+</div>
            <div class="text-sm text-text-tertiary">Usuarios activos</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">$2M+</div>
            <div class="text-sm text-text-tertiary">Ahorros generados</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">4.9★</div>
            <div class="text-sm text-text-tertiary">Rating promedio</div>
          </div>
        </div>
      </div>

      <!-- Right Column: Visual Elements -->
      <div class="relative flex justify-center items-center">
        <!-- Floating Backdrop Blur -->
        <div class="absolute inset-0 -z-10 bg-accent-blue/5 blur-3xl rounded-full scale-75 animate-pulse"></div>
        
        <div class="relative z-10 w-full max-w-[480px]">
          <div class="rounded-[2.5rem] overflow-hidden shadow-apple-lg border border-border-secondary shadow-indigo-500/10 transition-apple hover:scale-[1.02]">
            <img 
              src="/hero-principal.png" 
              alt="Capitalia App" 
              class="w-full h-auto"
            />
          </div>

          <!-- Floating Cards -->
          <div class="absolute -top-6 -left-12 hidden md:flex items-center gap-3 bg-surface-primary/80 glass border border-border-secondary p-4 rounded-2xl shadow-apple-sm animate-apple-float">
            <div class="p-2 bg-status-success/10 rounded-lg text-status-success">📈</div>
            <div>
              <div class="text-sm font-bold text-text-primary">+15% ahorro</div>
              <div class="text-[10px] text-text-tertiary">Este mes</div>
            </div>
          </div>

          <div class="absolute top-1/2 -right-16 hidden md:flex items-center gap-3 bg-surface-primary/80 glass border border-border-secondary p-4 rounded-2xl shadow-apple-sm animate-apple-float delay-700">
            <div class="p-2 bg-accent-blue/10 rounded-lg text-accent-blue">🏆</div>
            <div>
              <div class="text-sm font-bold text-text-primary">Meta alcanzada</div>
              <div class="text-[10px] text-text-tertiary">¡Felicidades!</div>
            </div>
          </div>

          <div class="absolute -bottom-8 -left-8 hidden md:flex items-center gap-3 bg-surface-primary/80 glass border border-border-secondary p-4 rounded-2xl shadow-apple-sm animate-apple-float delay-1000">
            <div class="p-2 bg-status-info/10 rounded-lg text-status-info">💡</div>
            <div>
              <div class="text-sm font-bold text-text-primary">Consejos de IA</div>
              <div class="text-[10px] text-text-tertiary">Analizando gastos...</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>