---
import { Card, CardTitle, CardDescription, CardContent } from "./ui/Card";
import { Button } from "./ui/Button";
import { Badge } from "./ui/Badge";
---

<section class="py-24 bg-surface-primary relative overflow-hidden">
  {/* Background Glow */}
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent-blue/5 blur-[120px] rounded-full -z-10"
  >
  </div>

  <div class="max-w-5xl mx-auto px-6">
    <Card
      client:load
      variant="elevated"
      padding="none"
      className="bg-accent-blue text-white overflow-hidden shadow-apple-2xl border-none"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_0%_0%,rgba(255,255,255,0.1),transparent_50%)]"
      >
      </div>

      <div
        class="relative z-10 p-12 md:p-20 text-center flex flex-col items-center gap-8"
      >
        <Badge
          client:load
          variant="primary"
          size="lg"
          className="bg-white/20 text-white border-none font-black tracking-widest px-6"
        >
          COMIENZA HOY
        </Badge>

        <h2
          class="text-4xl md:text-6xl font-black tracking-tight leading-[1.1] max-w-3xl"
        >
          ¿Listo para tomar control de tus finanzas?
        </h2>

        <p
          class="text-xl md:text-2xl opacity-90 leading-relaxed max-w-2xl font-medium"
        >
          Únete a más de 50,000 usuarios que ya transformaron su vida
          financiera. Es gratis, rápido y seguro.
        </p>

        <div
          class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto"
        >
          <Button
            client:load
            variant="secondary"
            size="lg"
            className="bg-white text-accent-blue! hover:bg-neutral-100 px-10 font-bold h-14 text-lg shadow-apple-lg border-none"
          >
            Descargar ahora
          </Button>
          <Button
            client:load
            variant="secondary"
            size="lg"
            className="bg-white/10 hover:bg-white/20 text-white border-white/20 px-10 font-bold h-14 text-lg"
          >
            Ver demo en vivo
          </Button>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-4 pt-10 border-t border-white/10 w-full max-w-2xl"
        >
          <div class="flex items-center gap-2 justify-center">
            <div
              class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center text-[10px]"
            >
              ✓
            </div>
            <span class="text-sm font-bold opacity-80 uppercase tracking-widest"
              >14 días gratis</span
            >
          </div>
          <div class="flex items-center gap-2 justify-center">
            <div
              class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center text-[10px]"
            >
              ✓
            </div>
            <span class="text-sm font-bold opacity-80 uppercase tracking-widest"
              >Sin tarjeta</span
            >
          </div>
          <div class="flex items-center gap-2 justify-center">
            <div
              class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center text-[10px]"
            >
              ✓
            </div>
            <span class="text-sm font-bold opacity-80 uppercase tracking-widest"
              >Cancela siempre</span
            >
          </div>
        </div>

        <div class="flex gap-4 items-center">
          <img
            src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png"
            alt="Google Play"
            class="h-14 opacity-90 hover:opacity-100 transition-apple"
          />
          {/* Placeholder for App Store if needed */}
        </div>
      </div>
    </Card>

    {/* Purchase Project CTA (Subtle) */}
    <div class="mt-12 text-center">
      <a
        href="/comprar"
        class="inline-flex items-center gap-2 text-text-tertiary hover:text-accent-blue transition-apple font-bold uppercase tracking-widest text-[11px]"
      >
        <span class="w-2 h-2 rounded-full bg-status-warning"></span>
        ¿Eres empresario? Adquiere el código fuente completo
      </a>
    </div>
  </div>
</section>
