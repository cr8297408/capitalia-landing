---
import { PricingGrid } from './PricingGrid';
import { FAQSection } from './FAQSection';
import { Card } from './ui/Card';
import { Badge } from './ui/Badge';

const faqs = []; // Los datos ahora están en FAQSection.tsx
---

<section id="pricing" class="py-24 bg-surface-primary relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <Badge client:load variant="default" size="md" className="mb-4 font-bold border-border-secondary">PLANES Y PRECIOS</Badge>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary mb-6 leading-tight">
        Elige el plan <span class="text-accent-blue underline decoration-accent-blue/10 underline-offset-8">perfecto</span> para ti
      </h2>
      <p class="text-xl text-text-secondary leading-relaxed">
        Comienza gratis y desbloquea funcionalidades premium cuando las necesites. Sin contratos a largo plazo.
      </p>
    </div>

    {/* React Pricing Grid */}
    <PricingGrid client:load />

    {/* FAQ Section */}
    <div class="mt-32 max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-extrabold text-text-primary mb-4">Preguntas Frecuentes</h3>
        <p class="text-text-secondary">Encuentra respuestas a las dudas más comunes sobre Capitalia.</p>
      </div>

      <FAQSection client:load />
    </div>

    {/* Trust Banner */}
    <Card client:load variant="flat" padding="lg" className="mt-24 border border-border-secondary/40 bg-surface-secondary/30">
      <div class="flex flex-wrap items-center justify-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-apple duration-500">
        <div class="text-xl font-black tracking-tighter text-text-primary">STRIPE</div>
        <div class="text-xl font-bold tracking-tight text-text-primary italic">SecurePay</div>
        <div class="text-xl font-black text-text-primary">DECRYPT</div>
        <div class="text-xl font-extrabold text-text-primary tracking-widest">TRUSTEE</div>
      </div>
    </Card>
  </div>
</section>