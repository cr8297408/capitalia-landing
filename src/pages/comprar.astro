---
import Layout from "../layouts/Layout.astro";
import {
  NavBar,
  NavBarBrand,
  NavBarContent,
  NavBarItem,
} from "../components/ui/NavBar";
import { Card, CardContent } from "../components/ui/Card";
import { Button } from "../components/ui/Button";
import { Badge } from "../components/ui/Badge";
import Footer from "../components/Footer.astro";
---

<Layout title="Adquiere el Proyecto Capitalia - Solución Completa de Finanzas">
  <main class="relative min-h-screen pt-20 overflow-hidden bg-surface-primary">
    <!-- Mesh Gradient Background -->
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_0%,rgba(0,102,204,0.08),transparent_50%),radial-gradient(circle_at_100%_100%,rgba(0,102,204,0.05),transparent_50%)]"
    >
    </div>

    <!-- NavBar -->
    <NavBar client:load>
      <NavBarBrand href="/" className="flex items-center gap-2">
        <span class="text-2xl">💰</span>
        <span class="font-bold tracking-tight text-text-primary">Capitalia</span
        >
      </NavBarBrand>

      <NavBarContent align="center" className="hidden md:flex">
        <NavBarItem href="/#features">Características</NavBarItem>
        <NavBarItem href="/#pricing">Precios</NavBarItem>
        <NavBarItem href="mailto:coder4021@gmail.com">Contacto</NavBarItem>
      </NavBarContent>

      <NavBarContent align="right" className="flex items-center gap-4">
        <a
          href="https://play.google.com/apps/testing/com.cr8297408.capitalia"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Button client:load variant="primary" size="sm" className="px-6">
            Descargar App
          </Button>
        </a>
      </NavBarContent>
    </NavBar>

    <div class="max-w-7xl mx-auto px-6 pt-20 pb-32">
      <!-- Purchase Hero -->
      <div class="flex flex-col items-center text-center gap-8 mb-24">
        <Badge
          client:load
          variant="primary"
          size="lg"
          className="font-black tracking-widest px-6 shadow-apple-sm"
        >
          🚀 OPORTUNIDAD EMPRESARIAL
        </Badge>

        <h1
          class="text-5xl md:text-7xl font-extrabold tracking-tight text-text-primary leading-[1.1] max-w-4xl"
        >
          Adquiere el <span class="text-accent-blue">Proyecto Completo</span>
        </h1>

        <p
          class="text-xl md:text-2xl text-text-secondary leading-relaxed max-w-2xl font-medium"
        >
          Solución integral de finanzas personales lista para lanzar. Código
          fuente, arquitectura enterprise y documentación técnica incluidos.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-4">
          <a
            href="mailto:coder4021@gmail.com?subject=Interés en adquirir Capitalia&body=Hola, estoy interesado en adquirir el proyecto completo de Capitalia. Me gustaría agendar una demostración."
          >
            <Button
              client:load
              variant="primary"
              size="lg"
              className="px-10 h-14 text-lg"
            >
              Solicitar Demostración
            </Button>
          </a>
          <a href="#investment">
            <Button
              client:load
              variant="secondary"
              size="lg"
              className="px-10 h-14 text-lg bg-surface-secondary/50 border-border-secondary/50"
            >
              Ver Inversión
            </Button>
          </a>
        </div>
      </div>

      <!-- Value Pillars -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-32">
        <Card
          client:load
          variant="flat"
          className="bg-surface-secondary/30 border-border-secondary/50 hover:border-accent-blue/30 transition-apple-lg"
        >
          <CardContent className="p-8 text-center space-y-4">
            <div class="text-4xl mb-2">📱</div>
            <h3 class="text-xl font-bold text-text-primary">
              App Móvil Completa
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              React Native con Expo, navegación avanzada y funcionalidades
              offline-first implementadas.
            </p>
          </CardContent>
        </Card>

        <Card
          client:load
          variant="flat"
          className="bg-surface-secondary/30 border-border-secondary/50 hover:border-accent-blue/30 transition-apple-lg"
        >
          <CardContent className="p-8 text-center space-y-4">
            <div class="text-4xl mb-2">🏗️</div>
            <h3 class="text-xl font-bold text-text-primary">
              Arquitectura Enterprise
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Código limpio con Scope Rule Pattern, TypeScript estricto y
              documentación técnica completa.
            </p>
          </CardContent>
        </Card>

        <Card
          client:load
          variant="flat"
          className="bg-surface-secondary/30 border-border-secondary/50 hover:border-accent-blue/30 transition-apple-lg"
        >
          <CardContent className="p-8 text-center space-y-4">
            <div class="text-4xl mb-2">💳</div>
            <h3 class="text-xl font-bold text-text-primary">
              Sistema de Pagos
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Integración robusta con Stripe/Wompi, suscripciones y gestión de
              facturación automatizada.
            </p>
          </CardContent>
        </Card>

        <Card
          client:load
          variant="flat"
          className="bg-surface-secondary/30 border-border-secondary/50 hover:border-accent-blue/30 transition-apple-lg"
        >
          <CardContent className="p-8 text-center space-y-4">
            <div class="text-4xl mb-2">🚀</div>
            <h3 class="text-xl font-bold text-text-primary">
              Production Ready
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed">
              Base de datos configurada, auth, notificaciones push y analíticas
              listas para el despliegue.
            </p>
          </CardContent>
        </Card>
      </div>

      <!-- Technical Specifications Section -->
      <section class="mb-32">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-text-primary mb-4">
            Especificaciones Técnicas
          </h2>
          <p class="text-text-secondary">
            Tecnología de última generación diseñada para escalar.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <Card
            client:load
            variant="elevated"
            className="bg-surface-secondary/20 border-border-secondary/30"
          >
            <CardContent className="p-10">
              <div class="flex items-center gap-4 mb-8">
                <div class="p-3 bg-accent-blue/10 rounded-2xl text-accent-blue">
                  ✨
                </div>
                <h3 class="text-2xl font-bold text-text-primary">
                  Frontend Mobile
                </h3>
              </div>
              <ul class="space-y-4">
                {
                  [
                    "React Native + Expo SDK 50+",
                    "TypeScript estricto",
                    "React Navigation v6",
                    "Shadcn UI adaptado para Mobile",
                    "Animaciones Reanimated & Framer Motion",
                    "Offline-first con SQLite nativo",
                  ].map((spec) => (
                    <li class="flex items-center gap-3 text-text-secondary text-sm">
                      <span class="w-1.5 h-1.5 rounded-full bg-accent-blue" />
                      {spec}
                    </li>
                  ))
                }
              </ul>
            </CardContent>
          </Card>

          <Card
            client:load
            variant="elevated"
            className="bg-surface-secondary/20 border-border-secondary/30"
          >
            <CardContent className="p-10">
              <div class="flex items-center gap-4 mb-8">
                <div
                  class="p-3 bg-status-success/10 rounded-2xl text-status-success"
                >
                  🔐
                </div>
                <h3 class="text-2xl font-bold text-text-primary">
                  Backend & Database
                </h3>
              </div>
              <ul class="space-y-4">
                {
                  [
                    "Supabase PostgreSQL (Self-hosted ready)",
                    "Row Level Security (RLS) configurado",
                    "Edge Functions en Deno",
                    "Realtime Channel subscriptions",
                    "Sistema de migraciones automatizado",
                    "Backup automático y escalable",
                  ].map((spec) => (
                    <li class="flex items-center gap-3 text-text-secondary text-sm">
                      <span class="w-1.5 h-1.5 rounded-full bg-status-success" />
                      {spec}
                    </li>
                  ))
                }
              </ul>
            </CardContent>
          </Card>
        </div>
      </section>

      <!-- Investment Card -->
      <section id="investment" class="max-w-4xl mx-auto mb-32">
        <Card
          client:load
          variant="elevated"
          className="relative overflow-hidden border-2 border-accent-blue ring-4 ring-accent-blue/10 shadow-apple-2xl"
        >
          <div
            class="absolute top-0 right-0 w-64 h-64 bg-accent-blue/5 blur-[80px] rounded-full -mr-32 -mt-32"
          >
          </div>

          <CardContent className="p-12 md:p-20 text-center">
            <h2 class="text-3xl md:text-5xl font-black text-text-primary mb-2">
              Inversión del Proyecto
            </h2>
            <p
              class="text-text-tertiary font-bold uppercase tracking-[0.2em] text-xs mb-12"
            >
              FULL SOURCE CODE LICENSE
            </p>

            <div class="flex flex-col items-center gap-2 mb-12">
              <span class="text-lg text-text-tertiary line-through font-medium"
                >Valor de desarrollo: $50,000+ USD</span
              >
              <div class="flex items-baseline gap-1">
                <span class="text-2xl font-bold text-accent-blue">$</span>
                <span
                  class="text-7xl font-black text-text-primary tracking-tighter"
                  >15,000</span
                >
                <span
                  class="text-xl font-bold text-text-tertiary uppercase ml-2"
                  >USD</span
                >
              </div>
              <Badge
                client:load
                variant="success"
                size="md"
                className="mt-4 font-bold">AHORRA $35,000+ EN TRABAJO</Badge
              >
            </div>

            <div
              class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-left max-w-2xl mx-auto mb-16"
            >
              {
                [
                  "Licencia comercial completa",
                  "Código fuente 100% editable",
                  "Transferencia de propiedad GIT",
                  "Configuración de producción",
                  "Documentación empresarial",
                  "30 días de soporte post-venta",
                ].map((benefit) => (
                  <div class="flex items-center gap-3">
                    <div class="w-6 h-6 rounded-full bg-status-success/10 flex items-center justify-center text-status-success text-xs">
                      ✓
                    </div>
                    <span class="text-sm font-medium text-text-secondary">
                      {benefit}
                    </span>
                  </div>
                ))
              }
            </div>

            <div class="flex flex-col sm:flex-row justify-center gap-4">
              <a
                href="mailto:coder4021@gmail.com?subject=Adquisición Capitalia"
                class="flex-1"
              >
                <Button
                  client:load
                  variant="primary"
                  className="w-full h-16 text-lg font-bold shadow-apple-lg"
                >
                  Contactar por Email
                </Button>
              </a>
              <a
                href="https://wa.me/+573133711108?text=Hola, estoy interesado en adquirir el proyecto Capitalia"
                class="flex-1"
              >
                <Button
                  client:load
                  variant="secondary"
                  className="w-full h-16 text-lg font-bold border-status-success/20 text-status-success! hover:bg-status-success/5"
                >
                  WhatsApp Directo
                </Button>
              </a>
            </div>

            <p class="mt-8 text-xs text-text-tertiary font-medium">
              * El precio incluye transferencia de dominio y configuración
              inicial en tu servidor CubePath.
            </p>
          </CardContent>
        </Card>
      </section>
    </div>

    <Footer />
  </main>
</Layout>
